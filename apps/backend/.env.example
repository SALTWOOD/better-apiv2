# PostgreSQL Database URL
# Example: postgresql://user:password@localhost:5432/pcl_ce_api
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/pcl_ce_api?schema=public"

# Server Port
PORT=3000

# Node Environment
NODE_ENV="development"

# GitHub OAuth for Admin Login
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="http://localhost:3000/auth/github/callback"
GITHUB_ORG="PCL-Community"
GITHUB_TEAM_SLUG="ce-dev"

# Admin Session
ADMIN_SESSION_TTL_HOURS=24

REDIS_URL=redis://default:password@localhost:6379

# 存储服务配置
# 可选值: 's3' | 'r2' | 'local'
STORAGE_PROVIDER=local

##### NOTE: ONLY LOCAL WAS TESTED, PLEASE CONFIGURE OTHER PROVIDERS CAREFULLY #####

# AWS S3 配置
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1

# Cloudflare R2 配置
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# S3_REGION=auto

S3_BUCKET=pcl-community
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# 本地存储目录（在 STORAGE_PROVIDER=local 时使用）
UPLOAD_DIR=./uploads

# 补丁生成并发数
PATCH_CONCURRENCY=2

BSDIFF_COMMAND="path/to/bsdiff"
BSPATCH_COMMAND="path/to/bspatch"
